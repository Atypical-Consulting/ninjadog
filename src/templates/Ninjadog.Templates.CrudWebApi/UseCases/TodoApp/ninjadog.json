{
  "$schema": "https://ninjadog.dev/schemas/ninjadog.schema.json",
  "config": {
    "name": "TodoApp",
    "version": "1.0.0",
    "description": "An application to manage todo lists.",
    "rootNamespace": "TodoApp.CrudWebApi"
  },
  "entities": {
    "TodoList": {
      "properties": {
        "Id": {
          "type": "Guid",
          "isKey": true
        },
        "Title": {
          "type": "string"
        }
      },
      "relationships": {
        "Items": {
          "relatedEntity": "TodoItem",
          "relationshipType": "OneToMany"
        },
        "Categories": {
          "relatedEntity": "TodoCategory",
          "relationshipType": "OneToMany"
        }
      }
    },
    "TodoItem": {
      "properties": {
        "Id": {
          "type": "Guid",
          "isKey": true
        },
        "Description": {
          "type": "string"
        },
        "IsCompleted": {
          "type": "bool"
        },
        "DueDate": {
          "type": "DateTime"
        }
      }
    },
    "TodoCategory": {
      "properties": {
        "Id": {
          "type": "Guid",
          "isKey": true
        },
        "Name": {
          "type": "string"
        },
        "Color": {
          "type": "string"
        },
        "Icon": {
          "type": "string"
        }
      }
    }
  }
}
