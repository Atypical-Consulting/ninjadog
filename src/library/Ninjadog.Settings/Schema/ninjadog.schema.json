{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ninjadog Configuration",
  "description": "Schema for ninjadog.json configuration files used by the Ninjadog code generator.",
  "type": "object",
  "required": ["config", "entities"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to the JSON schema for editor support."
    },
    "config": {
      "type": "object",
      "description": "General configuration settings for the Ninjadog Engine.",
      "required": ["name", "version", "description", "rootNamespace"],
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the application or project."
        },
        "version": {
          "type": "string",
          "description": "The version of the application or project."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the application or project."
        },
        "rootNamespace": {
          "type": "string",
          "description": "The root namespace for the generated code."
        },
        "outputPath": {
          "type": "string",
          "description": "The path where generated files will be saved."
        },
        "saveGeneratedFiles": {
          "type": "boolean",
          "description": "Whether to save generated files to disk."
        },
        "cors": {
          "type": "object",
          "description": "CORS configuration for the application.",
          "required": ["origins"],
          "properties": {
            "origins": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Allowed CORS origins."
            },
            "methods": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Allowed HTTP methods."
            },
            "headers": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Allowed HTTP headers."
            }
          },
          "additionalProperties": false
        },
        "features": {
          "type": "object",
          "description": "Feature toggles for the code generator.",
          "properties": {
            "softDelete": {
              "type": "boolean",
              "description": "Enable soft delete support."
            },
            "auditing": {
              "type": "boolean",
              "description": "Enable audit fields (CreatedAt, UpdatedAt)."
            }
          },
          "additionalProperties": false
        },
        "database": {
          "type": "object",
          "description": "Database configuration.",
          "properties": {
            "provider": {
              "type": "string",
              "enum": ["sqlite", "postgresql", "sqlserver"],
              "description": "The database provider to use."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "entities": {
      "type": "object",
      "description": "Entity definitions for code generation.",
      "additionalProperties": {
        "type": "object",
        "required": ["properties"],
        "properties": {
          "properties": {
            "type": "object",
            "description": "Property definitions for the entity.",
            "additionalProperties": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": {
                  "type": "string",
                  "description": "The data type of the property."
                },
                "isKey": {
                  "type": "boolean",
                  "description": "Whether this property is the primary key."
                },
                "required": {
                  "type": "boolean",
                  "description": "Whether this property is required."
                },
                "maxLength": {
                  "type": "integer",
                  "description": "Maximum length constraint for string properties."
                },
                "minLength": {
                  "type": "integer",
                  "description": "Minimum length constraint for string properties."
                },
                "min": {
                  "type": "integer",
                  "description": "Minimum value constraint for numeric properties."
                },
                "max": {
                  "type": "integer",
                  "description": "Maximum value constraint for numeric properties."
                },
                "pattern": {
                  "type": "string",
                  "description": "Regex pattern constraint for string properties."
                }
              },
              "additionalProperties": false
            }
          },
          "relationships": {
            "type": "object",
            "description": "Relationship definitions for the entity.",
            "additionalProperties": {
              "type": "object",
              "required": ["relatedEntity", "type"],
              "properties": {
                "relatedEntity": {
                  "type": "string",
                  "description": "The name of the related entity."
                },
                "type": {
                  "type": "string",
                  "enum": ["OneToOne", "OneToMany", "ManyToMany", "OneWay", "ManyWay"],
                  "description": "The type of relationship."
                }
              },
              "additionalProperties": false
            }
          },
          "seedData": {
            "type": "array",
            "description": "Seed data for the entity.",
            "items": {
              "type": "object"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "enums": {
      "type": "object",
      "description": "Enum definitions for code generation.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
